    "msys2_prefix": "mingw64",
    "gdk_backend": "win32",
    "gtk_theme": "io.elementary.stylesheet.blueberry",
    "gtk_icon_theme": "Adwaita",
    "gtk_font_name": "Inter Variable Text 9",
    "build_dir": "build-windows-x86_64",
