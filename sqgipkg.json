    ],
    "nsis_options": {
      "installer_name": "Badger-Setup.exe",
      "install_dir": "$LOCALAPPDATA\\Programs\\com.github.elfenware.badger",
      "request_execution_level": "user",
      "desktop_shortcut": true,
      "start_menu_shortcut": true,
      "start_menu_folder": "Badger",
      "uninstall_registry": true
    }
